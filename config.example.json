{
  "_comment": "Copy this to ~/.claude/hooks/config.json and fill in your values.",
  "ntfy": {
    "topic": "YOUR_LONG_RANDOM_TOPIC",
    "server": "https://ntfy.sh"
  },
  "summarizer": {
    "enabled": true,
    "model": "claude-haiku-3-5",
    "api_key_env": "ANTHROPIC_API_KEY"
  },
  "auto_approve": [
    "ls*",
    "cat*",
    "pwd",
    "whoami",
    "echo*",
    "git status*",
    "git branch*",
    "git log*",
    "git diff*",
    "git show*"
  ],
  "callback_port": 45678,
  "escalation_delay_seconds": 10,
  "macos_dialog": false,
  "timeout_seconds": 60,
  "timeout_action": "deny"
}